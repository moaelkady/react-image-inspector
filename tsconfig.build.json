{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/index.ts", "src/components/**/*", "src/**/*.d.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
